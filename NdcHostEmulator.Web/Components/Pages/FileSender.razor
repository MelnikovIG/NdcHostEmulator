@page "/files"
@inject TcpServerService TcpService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>FileSender — NDC Host Emulator</PageTitle>

<div style="display: flex; flex-direction: column; height: 100%;">

@if (!TcpService.IsClientConnected)
{
    <MudAlert Severity="Severity.Warning" Class="mb-3">
        Нет подключённого клиента. Подождите подключения банкомата.
    </MudAlert>
}

<div style="flex: 1; overflow: hidden;">
<MudGrid Spacing="3" Style="height: 100%;">
    <!-- Таблица файлов -->
    <MudItem xs="12" md="4" Style="height: 100%;">
        <MudCard Elevation="2" Style="height: 100%; display: flex; flex-direction: column;">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Файлы для отправки</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_filesDirectory</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudTooltip Text="Обновить список">
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       OnClick="LoadFiles" />
                    </MudTooltip>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0" Style="flex: 1; overflow-y: auto; min-height: 0;">
                @if (_files.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Class="ma-3">
                        В директории нет файлов: @_filesDirectory
                    </MudAlert>
                }
                else
                {
                    <MudDataGrid T="FileItem"
                                 Items="_files"
                                 Hover="true"
                                 Dense="true"
                                 RowClick="OnRowClick"
                                 RowClass="cursor-pointer"
                                 RowClassFunc="GetRowClass">
                        <Columns>
                            <PropertyColumn Property="x => x.Name" Title="Имя файла" />
                            <PropertyColumn Property="x => x.SizeFormatted" Title="Размер" Sortable="false" />
                            <PropertyColumn Property="x => x.LastModified" Title="Изменён"
                                            Format="dd.MM.yy HH:mm" />
                        </Columns>
                    </MudDataGrid>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Панель предпросмотра и отправки -->
    <MudItem xs="12" md="8" Style="height: 100%;">
        <MudCard Elevation="2" Style="height: 100%; display: flex; flex-direction: column;">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@(_selectedFile?.Name ?? "Редактор")</MudText>
                    @if (_selectedFile != null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedFile.SizeFormatted</MudText>
                    }
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="SendSelectedFile"
                               Disabled="@(!TcpService.IsClientConnected || _isSending)"
                               Size="Size.Small">
                        @if (_isSending)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Отправка...</span>
                        }
                        else
                        {
                            <span>Отправить</span>
                        }
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0" Style="flex: 1; overflow: hidden; display: flex; flex-direction: column; min-height: 0;">
                <div @ref="_editorRef"
                     contenteditable="true"
                     spellcheck="false"
                     style="flex: 1; margin: 0; padding: 10px 12px; font-family: monospace; font-size: 11px;
                            background: #1e1e1e; color: #ccc; overflow: auto;
                            white-space: pre-wrap; word-break: break-all; min-height: 0;
                            border: none; outline: none; box-sizing: border-box;"></div>
            </MudCardContent>
        </MudCard>

        @if (_sendResult != null)
        {
            <MudAlert Severity="@_sendResult.Severity" Class="mt-3" ShowCloseIcon="true" CloseIconClicked="ClearResult">
                @_sendResult.Message
            </MudAlert>
        }
    </MudItem>
</MudGrid>
</div>
</div>

@code {
    private sealed record FileItem(string Name, string FullPath, long SizeBytes, DateTime LastModified)
    {
        public string SizeFormatted => SizeBytes >= 1024
            ? $"{SizeBytes / 1024.0:F1} KB"
            : $"{SizeBytes} B";
    }

    private sealed record SendResultInfo(Severity Severity, string Message);

    private List<FileItem> _files = new();
    private FileItem? _selectedFile;
    private string _preview = string.Empty;
    private bool _isSending;
    private SendResultInfo? _sendResult;
    private string _filesDirectory = string.Empty;
    private ElementReference _editorRef;
    private bool _needsEditorUpdate;

    protected override void OnInitialized()
    {
        TcpService.OnConnectionChanged += OnConnectionChanged;
        LoadFiles();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsEditorUpdate)
        {
            _needsEditorUpdate = false;
            await JS.InvokeVoidAsync("contentEditor.setHtml", _editorRef, FormatPreview(_preview).Value);
        }
    }

    private void LoadFiles()
    {
        _filesDirectory = TcpService.FilesDirectory;

        if (!Directory.Exists(_filesDirectory))
        {
            _files = new();
            return;
        }

        _files = Directory.GetFiles(_filesDirectory)
            .Select(f => new FileInfo(f))
            .OrderBy(f => f.Name)
            .Select(f => new FileItem(f.Name, f.FullName, f.Length, f.LastWriteTime))
            .ToList();

        if (_selectedFile != null && !_files.Any(f => f.FullPath == _selectedFile.FullPath))
        {
            _selectedFile = null;
            _preview = string.Empty;
        }
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<FileItem> args)
    {
        var file = args.Item;
        _selectedFile = file;
        _sendResult = null;
        _preview = string.Empty;

        if (file == null) return;

        try
        {
            _preview = await File.ReadAllTextAsync(file.FullPath);
        }
        catch (Exception ex)
        {
            _preview = $"Ошибка чтения: {ex.Message}";
        }

        _needsEditorUpdate = true;
    }

    private static MarkupString FormatPreview(string text)
    {
        var sb = new System.Text.StringBuilder(text.Length * 2);
        foreach (char c in text)
        {
            if (c < 0x20 && c != '\n' && c != '\r' && c != '\t')
                sb.Append($"<span class=\"ctrl-pic\">{(char)(0x2400 + c)}</span>");
            else if (c == 0x7F)
                sb.Append("<span class=\"ctrl-pic\">\u2421</span>");
            else
                sb.Append(c switch { '<' => "&lt;", '>' => "&gt;", '&' => "&amp;", _ => c.ToString() });
        }
        return new MarkupString(sb.ToString());
    }

    private static string ExtractTextFromEditor(string innerText)
    {
        var sb = new System.Text.StringBuilder(innerText.Length);
        foreach (char c in innerText)
        {
            if (c >= 0x2400 && c <= 0x241F)
                sb.Append((char)(c - 0x2400));
            else if (c == 0x2421)
                sb.Append((char)0x7F);
            else
                sb.Append(c);
        }
        return sb.ToString();
    }

    private string GetRowClass(FileItem item, int _)
    {
        return _selectedFile != null && item.FullPath == _selectedFile.FullPath
            ? "mud-theme-primary"
            : string.Empty;
    }

    private async Task SendSelectedFile()
    {
        _isSending = true;
        _sendResult = null;

        try
        {
            var raw = await JS.InvokeAsync<string>("contentEditor.getText", _editorRef);
            var content = ExtractTextFromEditor(raw);

            var sw = System.Diagnostics.Stopwatch.StartNew();
            await TcpService.SendContent(content);
            sw.Stop();

            _sendResult = new SendResultInfo(
                Severity.Success,
                $"{(_selectedFile != null ? $"'{_selectedFile.Name}' о" : "О")}тправлено за {sw.Elapsed.TotalSeconds:F2} с"
            );
        }
        catch (Exception ex)
        {
            _sendResult = new SendResultInfo(Severity.Error, $"Ошибка: {ex.Message}");
        }
        finally
        {
            _isSending = false;
        }
    }

    private void ClearResult() => _sendResult = null;

    private void OnConnectionChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TcpService.OnConnectionChanged -= OnConnectionChanged;
    }
}
