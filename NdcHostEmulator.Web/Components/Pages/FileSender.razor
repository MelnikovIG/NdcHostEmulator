@page "/files"
@inject TcpServerService TcpService
@implements IDisposable

<PageTitle>FileSender — NDC Host Emulator</PageTitle>

@if (!TcpService.IsClientConnected)
{
    <MudAlert Severity="Severity.Warning" Class="mb-3">
        Нет подключённого клиента. Подождите подключения банкомата.
    </MudAlert>
}

<MudGrid Spacing="3">
    <!-- Таблица файлов -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Файлы для отправки</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_filesDirectory</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudTooltip Text="Обновить список">
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       OnClick="LoadFiles" />
                    </MudTooltip>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                @if (_files.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Class="ma-3">
                        В директории нет файлов: @_filesDirectory
                    </MudAlert>
                }
                else
                {
                    <MudDataGrid T="FileItem"
                                 Items="_files"
                                 Hover="true"
                                 Dense="true"
                                 RowClick="OnRowClick"
                                 RowClass="cursor-pointer"
                                 RowClassFunc="GetRowClass">
                        <Columns>
                            <PropertyColumn Property="x => x.Name" Title="Имя файла" />
                            <PropertyColumn Property="x => x.SizeFormatted" Title="Размер" Sortable="false" />
                            <PropertyColumn Property="x => x.LastModified" Title="Изменён"
                                            Format="dd.MM.yy HH:mm" />
                        </Columns>
                    </MudDataGrid>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Панель предпросмотра и отправки -->
    <MudItem xs="12" md="5">
        @if (_selectedFile == null)
        {
            <MudAlert Severity="Severity.Info">Выберите файл из списка</MudAlert>
        }
        else
        {
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@_selectedFile.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedFile.SizeFormatted</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField T="string"
                                  Value="_preview"
                                  ReadOnly="true"
                                  Lines="8"
                                  Variant="Variant.Outlined"
                                  Label="Превью содержимого"
                                  Style="font-family: monospace; font-size: 11px;" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="SendSelectedFile"
                               Disabled="@(!TcpService.IsClientConnected || _isSending)"
                               FullWidth="true">
                        @if (_isSending)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Отправка...</span>
                        }
                        else
                        {
                            <span>Отправить</span>
                        }
                    </MudButton>
                </MudCardActions>
            </MudCard>

            @if (_sendResult != null)
            {
                <MudAlert Severity="@_sendResult.Severity" Class="mt-3" ShowCloseIcon="true" CloseIconClicked="ClearResult">
                    @_sendResult.Message
                </MudAlert>
            }
        }
    </MudItem>
</MudGrid>

@code {
    private sealed record FileItem(string Name, string FullPath, long SizeBytes, DateTime LastModified)
    {
        public string SizeFormatted => SizeBytes >= 1024
            ? $"{SizeBytes / 1024.0:F1} KB"
            : $"{SizeBytes} B";
    }

    private sealed record SendResultInfo(Severity Severity, string Message);

    private List<FileItem> _files = new();
    private FileItem? _selectedFile;
    private string _preview = string.Empty;
    private bool _isSending;
    private SendResultInfo? _sendResult;
    private string _filesDirectory = string.Empty;

    protected override void OnInitialized()
    {
        TcpService.OnConnectionChanged += OnConnectionChanged;
        LoadFiles();
    }

    private void LoadFiles()
    {
        _filesDirectory = TcpService.FilesDirectory;

        if (!Directory.Exists(_filesDirectory))
        {
            _files = new();
            return;
        }

        _files = Directory.GetFiles(_filesDirectory)
            .Select(f => new FileInfo(f))
            .OrderBy(f => f.Name)
            .Select(f => new FileItem(f.Name, f.FullName, f.Length, f.LastWriteTime))
            .ToList();

        // Сбросить выбор если файл больше не существует
        if (_selectedFile != null && !_files.Any(f => f.FullPath == _selectedFile.FullPath))
        {
            _selectedFile = null;
            _preview = string.Empty;
        }
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<FileItem> args)
    {
        var file = args.Item;
        _selectedFile = file;
        _sendResult = null;
        _preview = string.Empty;

        if (file == null) return;

        try
        {
            var content = await File.ReadAllTextAsync(file.FullPath);
            _preview = content.Length > 500
                ? content[..500] + "\n... (обрезано)"
                : content;
        }
        catch (Exception ex)
        {
            _preview = $"Ошибка чтения: {ex.Message}";
        }
    }

    private string GetRowClass(FileItem item, int _)
    {
        return _selectedFile != null && item.FullPath == _selectedFile.FullPath
            ? "mud-theme-primary"
            : string.Empty;
    }

    private async Task SendSelectedFile()
    {
        if (_selectedFile == null) return;

        _isSending = true;
        _sendResult = null;

        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            await TcpService.SendFile(_selectedFile.FullPath);
            sw.Stop();

            _sendResult = new SendResultInfo(
                Severity.Success,
                $"Файл '{_selectedFile.Name}' отправлен за {sw.Elapsed.TotalSeconds:F2} с"
            );
        }
        catch (Exception ex)
        {
            _sendResult = new SendResultInfo(Severity.Error, $"Ошибка: {ex.Message}");
        }
        finally
        {
            _isSending = false;
        }
    }

    private void ClearResult() => _sendResult = null;

    private void OnConnectionChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TcpService.OnConnectionChanged -= OnConnectionChanged;
    }
}
