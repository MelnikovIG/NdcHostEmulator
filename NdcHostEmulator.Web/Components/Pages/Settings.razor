@page "/settings"
@inject TerminalManager TerminalManager
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Настройки — NDC Host Emulator</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Терминалы</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudChip T="string" Color="Color.Info" Size="Size.Small">
                        @TerminalManager.Terminals.Count шт.
                    </MudChip>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (!TerminalManager.Terminals.Any())
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Нет сконфигурированных терминалов</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Bordered="true">
                        <thead>
                            <tr>
                                <th>Имя</th>
                                <th>Порт</th>
                                <th>Директория</th>
                                <th>Статус</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in TerminalManager.Terminals.OrderBy(x => x.Port))
                            {
                                <tr>
                                    <td>@t.Name</td>
                                    <td>@t.Port</td>
                                    <td style="font-size:12px;color:grey;">@t.FilesDirectory</td>
                                    <td>
                                        @if (t.IsClientConnected)
                                        { <MudChip T="string" Color="Color.Success" Size="Size.Small">Подключён</MudChip> }
                                        else if (t.IsListening)
                                        { <MudChip T="string" Color="Color.Warning" Size="Size.Small">Ожидание</MudChip> }
                                        else
                                        { <MudChip T="string" Color="Color.Default" Size="Size.Small">Остановлен</MudChip> }
                                    </td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Size="Size.Small" Color="Color.Error"
                                                       OnClick="@(() => RemoveAsync(t.Port))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">О программе</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="1">
                    <MudText><b>NDC Host Emulator</b> — Web Edition</MudText>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.body2">
                        Активных терминалов: @TerminalManager.Terminals.Count(t => t.IsListening)
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Подключённых клиентов: @TerminalManager.Terminals.Count(t => t.IsClientConnected)
                    </MudText>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    protected override void OnInitialized()
    {
        TerminalManager.OnTerminalsChanged += OnChanged;
        TerminalManager.OnAnyConnectionChanged += OnAnyConnectionChanged;
    }

    private async Task RemoveAsync(int port)
    {
        await TerminalManager.RemoveTerminal(port);
        Snackbar.Add($"Терминал на порту {port} удалён", Severity.Info);
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);
    private void OnAnyConnectionChanged(int _) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TerminalManager.OnTerminalsChanged -= OnChanged;
        TerminalManager.OnAnyConnectionChanged -= OnAnyConnectionChanged;
    }
}
