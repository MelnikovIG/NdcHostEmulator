@page "/logs"
@inject TcpServerService TcpService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Логи — NDC Host Emulator</PageTitle>

<!-- Toolbar -->
<MudPaper Elevation="1" Class="pa-3 mb-3">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudTextField T="string"
                          @bind-Value="_searchText"
                          Placeholder="Поиск по сообщению..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="5">
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                @foreach (var type in _allTypes)
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="@(_activeTypes.Contains(type) ? Variant.Filled : Variant.Outlined)"
                             Style="@($"color: {GetLogColor(type)}; border-color: {GetLogColor(type)}; cursor: pointer;")"
                             OnClick="@(() => ToggleType(type))">
                        @type
                    </MudChip>
                }
            </MudStack>
        </MudItem>
        <MudItem xs="6" sm="1">
            <MudSwitch T="bool" @bind-Value="_autoScroll" Color="Color.Primary" Label="Скролл" />
        </MudItem>
        <MudItem xs="6" sm="2" Class="d-flex justify-end align-center gap-2">
            <MudChip T="string" Size="Size.Small" Color="Color.Info">@FilteredLogs.Count()</MudChip>
            <MudTooltip Text="Очистить логи">
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                               Color="Color.Error"
                               OnClick="@(() => _showClearDialog = true)" />
            </MudTooltip>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Log area -->
<MudPaper Elevation="2" Style="background: #1e1e1e; overflow-y: auto; height: calc(100vh - 280px);">
    <div id="log-container" style="font-family: monospace; font-size: 12px;">
        @foreach (var entry in FilteredLogs)
        {
            <div style="padding: 2px 12px; border-bottom: 1px solid #2a2a2a;">
                <span style="color: #666; user-select: none;">[@entry.Timestamp.ToString("HH:mm:ss.fff")]</span>
                <span style="font-weight: bold; color: @GetLogColor(entry.Type);"> [@entry.Type]</span>
                <span style="color: #cccccc;"> @entry.Message</span>
            </div>
        }
        <div id="log-bottom"></div>
    </div>
</MudPaper>

<!-- Confirm clear dialog -->
@if (_showClearDialog)
{
    <MudOverlay Visible="true" DarkBackground="true" OnClick="@(() => _showClearDialog = false)" />
    <MudPaper Elevation="8"
              Style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; min-width: 350px;"
              Class="pa-6">
        <MudText Typo="Typo.h6" Class="mb-3">Очистить логи?</MudText>
        <MudText Class="mb-4">Список логов будет очищен. Файл tcp_sender.log не изменится.</MudText>
        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
            <MudButton OnClick="@(() => _showClearDialog = false)">Отмена</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ClearLogs">Очистить</MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    private static readonly string[] _allTypes =
        ["CONNECT", "DISCONNECT", "INCOMING", "OUTGOING", "DATA", "UTF8", "HEX", "ERROR", "SYSTEM"];

    private List<LogEntry> _logs = new();
    private string _searchText = string.Empty;
    private HashSet<string> _activeTypes = new(_allTypes);
    private bool _autoScroll = true;
    private bool _showClearDialog;

    private IEnumerable<LogEntry> FilteredLogs => _logs
        .Where(e => _activeTypes.Contains(e.Type))
        .Where(e => string.IsNullOrWhiteSpace(_searchText) ||
                    e.Message.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        _logs = TcpService.GetRecentLogs(500).ToList();
        TcpService.OnLogEntry += OnLogEntry;
    }

    private void OnLogEntry(LogEntry entry)
    {
        InvokeAsync(async () =>
        {
            _logs.Add(entry);
            if (_logs.Count > 1000)
                _logs.RemoveAt(0);
            StateHasChanged();

            if (_autoScroll)
            {
                await Task.Delay(50);
                await JS.InvokeVoidAsync("scrollToBottom", "log-bottom");
            }
        });
    }

    private void ToggleType(string type)
    {
        if (!_activeTypes.Remove(type))
            _activeTypes.Add(type);
    }

    private void ClearLogs()
    {
        _logs.Clear();
        _showClearDialog = false;
    }

    private static string GetLogColor(string type) => type switch
    {
        "CONNECT"    => "#4ec9b0",
        "DISCONNECT" => "#ce9178",
        "INCOMING"   => "#569cd6",
        "DATA"       => "#9cdcfe",
        "UTF8"       => "#b5cea8",
        "OUTGOING"   => "#4ec9b0",
        "HEX"        => "#808080",
        "ERROR"      => "#f44747",
        "SYSTEM"     => "#888888",
        _            => "#cccccc"
    };

    public void Dispose()
    {
        TcpService.OnLogEntry -= OnLogEntry;
    }
}
