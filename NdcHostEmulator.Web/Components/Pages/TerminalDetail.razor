@page "/terminal/{Port:int}"
@inject TerminalManager TerminalManager
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@implements IDisposable

@if (_terminal == null)
{
    <MudAlert Severity="Severity.Error">Терминал на порту @Port не найден.</MudAlert>
    <MudButton OnClick='() => Nav.NavigateTo("/")' Class="mt-2">← На главную</MudButton>
    return;
}

<PageTitle>@_terminal.Name — NDC Host Emulator</PageTitle>

<div style="height:100%;display:flex;flex-direction:column;overflow:hidden;">
<MudStack Spacing="0" Style="flex:1;min-height:0;overflow:hidden;">
    <!-- Breadcrumb -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
        <MudLink Href="/" Typo="Typo.body2" Color="Color.Primary">Dashboard</MudLink>
        <MudText Typo="Typo.body2" Color="Color.Secondary">/</MudText>
        <MudText Typo="Typo.body2">@_terminal.Name</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">(порт @Port)</MudText>
        <MudSpacer />
        @if (_terminal.IsClientConnected)
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Wifi">
                @_terminal.CurrentClientInfo
            </MudChip>
        }
        else if (_terminal.IsListening)
        {
            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.WifiFind">
                Ожидание подключения
            </MudChip>
        }
    </MudStack>

    <!-- Tabs -->
    <MudTabs Elevation="1" Rounded="false" @bind-ActivePanelIndex="_activeTab" Class="terminal-tabs" Style="flex:1;min-height:0;overflow:hidden;">

        <!-- Статус -->
        <MudTabPanel Text="Статус" Icon="@Icons.Material.Filled.Info">
            <MudGrid Spacing="3" Class="pa-3">
                <MudItem xs="12" md="5">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.h6">Соединение</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudText><b>Имя:</b> @_terminal.Name</MudText>
                                <MudText><b>Порт:</b> @_terminal.Port</MudText>
                                <MudText><b>Статус:</b>
                                    @if (_terminal.IsClientConnected)
                                    { <MudChip T="string" Color="Color.Success" Size="Size.Small">Подключён</MudChip> }
                                    else if (_terminal.IsListening)
                                    { <MudChip T="string" Color="Color.Warning" Size="Size.Small">Ожидание</MudChip> }
                                    else
                                    { <MudChip T="string" Color="Color.Default" Size="Size.Small">Остановлен</MudChip> }
                                </MudText>
                                @if (_terminal.IsClientConnected)
                                {
                                    <MudText><b>Клиент:</b> @_terminal.CurrentClientInfo</MudText>
                                }
                                <MudText><b>Директория:</b> @_terminal.FilesDirectory</MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            @if (_terminal.IsClientConnected)
                            {
                                <MudButton Color="Color.Error" Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.WifiOff"
                                           OnClick="DisconnectClientAsync">Отключить клиента</MudButton>
                            }
                            @if (_terminal.IsListening)
                            {
                                <MudButton Color="Color.Warning" Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.Stop"
                                           OnClick="StopAsync">Остановить</MudButton>
                            }
                            else
                            {
                                <MudButton Color="Color.Success" Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="StartAsync">Запустить</MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Файлы -->
        <MudTabPanel Text="Файлы" Icon="@Icons.Material.Filled.Folder">
            <div style="display:flex;height:100%;overflow:hidden;background:#1e1e1e;">

                <!-- Левая панель: список файлов -->
                <div style="width:200px;min-width:200px;border-right:1px solid #333;display:flex;flex-direction:column;">
                    <div style="padding:4px 8px;border-bottom:1px solid #333;display:flex;align-items:center;">
                        <MudText Typo="Typo.caption" Style="color:#888;flex:1;">Файлы</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small"
                                       Style="color:#666;padding:2px;"
                                       OnClick="LoadFiles" />
                    </div>
                    <div style="flex:1;min-height:0;overflow-y:auto;">
                        @if (_files.Count == 0)
                        {
                            <span style="color:#555;font-size:12px;padding:8px 12px;display:block;">Нет файлов</span>
                        }
                        @foreach (var f in _files)
                        {
                            <div style="padding:5px 12px;cursor:pointer;font-size:12px;font-family:monospace;
                                        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
                                        background:@(_selectedFile == f ? "#094771" : "transparent");
                                        color:@(_selectedFile == f ? "#fff" : "#bbb");"
                                 @onclick="() => LoadFileIntoEditor(f)">
                                @f.Name
                            </div>
                        }
                    </div>
                </div>

                <!-- Правая панель: тулбар + редактор -->
                <div style="flex:1;display:flex;flex-direction:column;min-width:0;">
                    <div style="padding:4px 8px;border-bottom:1px solid #333;display:flex;justify-content:flex-end;background:#252526;">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   OnClick="SendAsync"
                                   Disabled="@(!_terminal.IsClientConnected || _isSending)"
                                   Size="Size.Small">
                            @if (_isSending)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Отправка...</span>
                            }
                            else
                            {
                                <span>Отправить</span>
                            }
                        </MudButton>
                    </div>
                    <div style="flex:1;min-height:0;">
                        <div @ref="_editorRef"
                             contenteditable="true"
                             spellcheck="false"
                             style="height:100%;padding:10px 12px;font-family:monospace;font-size:11px;
                                    background:#1e1e1e;color:#ccc;overflow:auto;
                                    white-space:pre-wrap;word-break:break-all;
                                    border:none;outline:none;box-sizing:border-box;"></div>
                    </div>
                    @if (_sendResult != null)
                    {
                        <MudAlert Severity="@_sendResult.Severity" Dense="true"
                                  ShowCloseIcon="true" CloseIconClicked="() => _sendResult = null">
                            @_sendResult.Message
                        </MudAlert>
                    }
                </div>

            </div>
        </MudTabPanel>

    </MudTabs>
</MudStack>
<LiveLogPanel Port="Port" />
</div>

@code {
    [Parameter] public int Port { get; set; }

    private TcpTerminal? _terminal;
    private int _activeTab;
    private bool _isSending;

    // Files tab
    private sealed record FileItem(string Name, string FullPath);
    private sealed record SendResultInfo(Severity Severity, string Message);
    private List<FileItem> _files = new();
    private FileItem? _selectedFile;
    private SendResultInfo? _sendResult;
    private ElementReference _editorRef;
    private bool _needsEditorUpdate;
    private string _editorContent = string.Empty;

    protected override void OnInitialized()
    {
        _terminal = TerminalManager.GetByPort(Port);
        if (_terminal == null) return;

        _terminal.OnConnectionChanged += OnConnectionChanged;
        LoadFiles();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsEditorUpdate)
        {
            _needsEditorUpdate = false;
            await JS.InvokeVoidAsync("contentEditor.setHtml", _editorRef,
                FormatPreview(_editorContent).Value);
        }
    }

    private void LoadFiles()
    {
        if (_terminal == null) return;
        var dir = _terminal.FilesDirectory;
        if (!Directory.Exists(dir)) { _files = new(); return; }
        _files = Directory.GetFiles(dir)
            .Select(f => new FileInfo(f))
            .OrderBy(f => f.Name)
            .Select(f => new FileItem(f.Name, f.FullName))
            .ToList();
    }

    private async Task LoadFileIntoEditor(FileItem file)
    {
        _selectedFile = file;
        _sendResult = null;
        try { _editorContent = await File.ReadAllTextAsync(file.FullPath); }
        catch (Exception ex) { _editorContent = $"Ошибка чтения: {ex.Message}"; }
        _needsEditorUpdate = true;
    }

    private async Task SendAsync()
    {
        if (_terminal == null) return;
        _isSending = true;
        _sendResult = null;
        try
        {
            var raw = await JS.InvokeAsync<string>("contentEditor.getText", _editorRef);
            var content = ExtractText(raw);
            var sw = System.Diagnostics.Stopwatch.StartNew();
            await _terminal.SendContent(content);
            sw.Stop();
            _sendResult = new(Severity.Success,
                $"{(_selectedFile != null ? $"'{_selectedFile.Name}' о" : "О")}тправлено за {sw.Elapsed.TotalSeconds:F2} с");
        }
        catch (Exception ex) { _sendResult = new(Severity.Error, $"Ошибка: {ex.Message}"); }
        finally { _isSending = false; }
    }

    private async Task DisconnectClientAsync()
    {
        if (_terminal == null) return;
        await _terminal.DisconnectClient();
    }

    private async Task StartAsync()
    {
        if (_terminal == null) return;
        try { await _terminal.StartAsync(); }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
    }

    private async Task StopAsync()
    {
        if (_terminal == null) return;
        await _terminal.StopAsync();
    }

    private void OnConnectionChanged() => InvokeAsync(StateHasChanged);

    private static MarkupString FormatPreview(string text)
    {
        var sb = new System.Text.StringBuilder(text.Length * 2);
        foreach (char c in text)
        {
            if (c < 0x20 && c != '\n' && c != '\r' && c != '\t')
                sb.Append($"<span class=\"ctrl-pic\">{(char)(0x2400 + c)}</span>");
            else if (c == 0x7F) sb.Append("<span class=\"ctrl-pic\">␡</span>");
            else sb.Append(c switch { '<' => "&lt;", '>' => "&gt;", '&' => "&amp;", _ => c.ToString() });
        }
        return new MarkupString(sb.ToString());
    }

    private static string ExtractText(string s)
    {
        var sb = new System.Text.StringBuilder(s.Length);
        foreach (char c in s)
        {
            if (c >= 0x2400 && c <= 0x241F) sb.Append((char)(c - 0x2400));
            else if (c == 0x2421) sb.Append((char)0x7F);
            else sb.Append(c);
        }
        return sb.ToString();
    }

    public void Dispose()
    {
        if (_terminal == null) return;
        _terminal.OnConnectionChanged -= OnConnectionChanged;
    }
}
