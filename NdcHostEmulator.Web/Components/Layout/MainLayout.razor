@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@implements IDisposable

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="4" Color="Color.Primary">
        <MudText Typo="Typo.h6">NDC Host Emulator</MudText>
        <MudSpacer />
        <ConnectionStatusBar />
    </MudAppBar>
    <MudMainContent>
        <div style="display: flex; flex-direction: column; height: calc(100vh - 64px); overflow: hidden;">

            <MudTabs Elevation="0"
                     Rounded="false"
                     ApplyEffectsToContainer="true"
                     ActivePanelIndex="_activePanelIndex"
                     ActivePanelIndexChanged="OnTabChanged"
                     @ref="_tabs">
                <MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard" />
                <MudTabPanel Text="Файлы" Icon="@Icons.Material.Filled.Folder" />
                <MudTabPanel Text="Настройки" Icon="@Icons.Material.Filled.Settings" />
            </MudTabs>

            <div style="flex: 1; overflow: hidden;">
                <MudContainer MaxWidth="MaxWidth.ExtraLarge"
                              Style="height: 100%; overflow-y: auto; box-sizing: border-box; padding-top: 16px;">
                    @Body
                </MudContainer>
            </div>

            <LiveLogPanel />

        </div>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Произошла необработанная ошибка.
    <a href="." class="reload">Перезагрузить</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static readonly string[] TabUrls = ["/", "/files", "/settings"];

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#E91E63",
            AppbarBackground = "#1976D2",
            AppbarText = "#FFFFFF",
            Background = "#FAFAFA",
            Surface = "#FFFFFF",
            TextPrimary = "#212121",
            TextSecondary = "#757575",
            Divider = "#BDBDBD",
        }
    };

    private MudTabs? _tabs;
    private int _activePanelIndex;
    private bool _navigating;

    protected override void OnInitialized()
    {
        _activePanelIndex = GetTabIndexFromUrl();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var idx = GetTabIndexFromUrl();
        if (idx != _activePanelIndex)
        {
            _activePanelIndex = idx;
            _navigating = true;
            if (_tabs is not null)
            {
                InvokeAsync(async () =>
                {
                    await _tabs.ActivatePanelAsync(idx);
                    _navigating = false;
                    StateHasChanged();
                });
            }
            else
            {
                _navigating = false;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private int GetTabIndexFromUrl()
    {
        var path = new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrEmpty(path)) path = "/";

        var idx = Array.FindIndex(TabUrls, u => u == path);
        return idx >= 0 ? idx : 0;
    }

    private void OnTabChanged(int index)
    {
        if (_navigating) return;
        if (index >= 0 && index < TabUrls.Length && index != _activePanelIndex)
        {
            _activePanelIndex = index;
            NavigationManager.NavigateTo(TabUrls[index]);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
