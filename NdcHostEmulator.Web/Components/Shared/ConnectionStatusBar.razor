@inject TerminalManager TerminalManager
@implements IDisposable

@{
    var connected = TerminalManager.Terminals.Count(t => t.IsClientConnected);
    var listening = TerminalManager.Terminals.Count(t => t.IsListening);
    var total = TerminalManager.Terminals.Count;
}

@if (total == 0)
{
    <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.WifiOff">
        Нет терминалов
    </MudChip>
}
else if (connected > 0)
{
    <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Wifi">
        @connected / @total подключено
    </MudChip>
}
else if (listening > 0)
{
    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.WifiFind">
        @listening / @total ожидают
    </MudChip>
}
else
{
    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.WifiOff">
        @total остановлено
    </MudChip>
}

@code {
    protected override void OnInitialized()
    {
        TerminalManager.OnTerminalsChanged += OnChanged;
        TerminalManager.OnAnyConnectionChanged += OnAnyConnectionChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);
    private void OnAnyConnectionChanged(int _) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TerminalManager.OnTerminalsChanged -= OnChanged;
        TerminalManager.OnAnyConnectionChanged -= OnAnyConnectionChanged;
    }
}
